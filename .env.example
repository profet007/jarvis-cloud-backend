# ==========================================
#  JARVIS Cloud - variables de entorno
# ==========================================
# Copia este archivo a .env y rellena los valores.

# ENV: development o production
ENV=development

# ---- Base de datos ----
# En desarrollo: SQLite (no necesita instalar nada)
DATABASE_URL=sqlite+aiosqlite:///./jarvis.db
# En producción (Railway te la da automáticamente):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ---- Seguridad ----
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambiar-esto-en-produccion-por-algo-aleatorio-de-64-caracteres
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- URL base (importante para callbacks de OAuth) ----
# En desarrollo:
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# En producción será tu dominio: https://api.jarvis-app.com

# ---- Google OAuth ----
# Crear en https://console.cloud.google.com → credenciales → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ---- GitHub OAuth ----
# Crear en https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ---- DeepSeek (LLM) ----
# Tu master key — todos los usuarios usan ésta
DEEPSEEK_API_KEY=

# ---- Stripe (para sesiones futuras) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PREMIUM=

# ---- Resend (emails, sesiones futuras) ----
RESEND_API_KEY=
